# =========================
# Required
# =========================
RAG_SERVICE_AUTH_TOKEN=replace-with-shared-secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key
GEMINI_API_KEY=your-gemini-api-key

# Optional (only needed for OpenAI-based paths/features)
OPENAI_API_KEY=

# =========================
# Retrieval / indexing defaults
# =========================
RAG_DEFAULT_COLLECTION=default
RAG_SUPABASE_TABLE=rag_chunks
RAG_SUPABASE_MATCH_RPC=match_rag_chunks
RAG_TOPK_DEFAULT=8
RAG_TOPN_DEFAULT=3
RAG_INDEX_WINDOW_SECONDS=120
RAG_INDEX_WINDOW_OVERLAP_SECONDS=10
RAG_VIDEO_PADDING_SECONDS=30
RAG_TWO_STAGE_ENABLED=true
RAG_TWO_STAGE_PREFILTER_LIMIT=1200
RAG_TWO_STAGE_CANDIDATE_COUNT=120

# =========================
# Media processing defaults
# =========================
RAG_WHISPER_MODEL=whisper-1
RAG_TRANSCRIPT_LANGUAGE=de
RAG_TRANSCRIPT_TARGET_SPAN_SECONDS=40
RAG_TRANSCRIPT_MAX_SPAN_SECONDS=60
RAG_PDF_RENDER_TARGET_WIDTH=1280
RAG_PDF_RENDER_FORMAT=jpeg
RAG_PDF_RENDER_QUALITY=80

# =========================
# Optional S3 worker (leave empty to disable)
# Hetzner Object Storage: S3-kompatibel — Keys in der Hetzner Console erzeugen.
# Standorte: Endpoint + Region = gleicher Location-Code (fsn1 / nbg1 / hel1).
# Siehe https://docs.hetzner.com/storage/object-storage/getting-started/using-libraries/
# =========================
RAG_S3_ENDPOINT_URL=
RAG_S3_ACCESS_KEY_ID=
RAG_S3_SECRET_ACCESS_KEY=
# Region: bei Hetzner z. B. fsn1, nbg1, hel1 — nicht zwingend us-east-1
RAG_S3_REGION=us-east-1
# Hetzner-Doku (boto3) nutzt oft virtual; path ist Default im Service — bei 403/Signature-Fehlern virtual probieren
RAG_S3_ADDRESSING_STYLE=path
# Kommagetrennte Bucket-Namen (leer = alle erlaubt, aber dann nur noch Key-Prefix-Checks)
RAG_S3_ALLOWED_BUCKETS=
RAG_S3_KEY_PREFIX_ALLOWLIST=

# Beispiel Hetzner (FSN1), Werte einsetzen und oben aktivieren:
# RAG_S3_ENDPOINT_URL=https://fsn1.your-objectstorage.com
# RAG_S3_ACCESS_KEY_ID=...
# RAG_S3_SECRET_ACCESS_KEY=...
# RAG_S3_REGION=fsn1
# RAG_S3_ADDRESSING_STYLE=virtual
# RAG_S3_ALLOWED_BUCKETS=mein-bucket
